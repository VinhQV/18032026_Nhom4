static void BuzzerControl_SetStatus(GPIO_TypeDef * GPIOx, uint8_t GPIO_PIN, uint8_t Status)
{
    //Set bit in BSRR Registers---------------------------------------------
    if (Status == GPIO_PIN_SET)
    {
        GPIOx->BSRRL |= 1 << GPIO_PIN;
    }

    //Reset bit in BSRR Registers-------------------------------------------
    if (Status == GPIO_PIN_RESET)
    {
        GPIOx->BSRRH |= 1 << GPIO_PIN;
    }
}

static uint8_t Button_GetLogic(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin)
{
	return GPIO_ReadInputDataBit(GPIOx, GPIO_Pin);
}

void Delay_ms(uint32_t ms){
	//loop forever
	for(uint32_t i = 0; i < ms ; i++)
	{
		for(uint32_t j = 0;j < 5000; j++);
	}
}

int main(void)
{
	// System clock 84MHz ------------------------------------------------------
	SystemCoreClockUpdate();

	// Initializes Button User -------------------------------------------------
	Button_Init();

	// Initializes Led ---------------------------------------------------------
//	Led_Init();

    /* Loop forever */
	while(1)
	    {
	        // //Nhan nut thi keo xuong khong
	        if (Button_GetLogic(BUTTON_GPIO_PORT, BUTTON_GPIO_PIN) == 0)
	        {
	            //on
	        	BuzzerControl_SetStatus(BUZZER_GPIO_PORT, BUZZER_GPIO_PIN, GPIO_PIN_SET);
	        }
	        else //Pull up tro lai muc logic 1
	        {
	            //off
	        	BuzzerControl_SetStatus(BUZZER_GPIO_PORT, BUZZER_GPIO_PIN, GPIO_PIN_RESET);
	        }
	    }
}


