#include <system_stm32f4xx.h>
#include <stdint.h>
#include <timer.h>
#include <Ucglib.h>

static ucg_t ucg;

int main(void)
{
    SystemCoreClockUpdate();    // Call ham cap xung clock
    TimerInit();               // để khởi tạo chức năng timer.

    //LCD Init
    Ucglib4WireSWSPI_begin(&ucg, UCG_FONT_MODE_SOLID);
    ucg_ClearScreen(&ucg);

    ucg_SetFont(&ucg,ucg_font_courR12_mf); //Co chu va font
    ucg_SetColor(&ucg, 0, 255, 255, 255);  // text colo
    ucg_SetColor(&ucg, 1, 0, 0, 0);        // màu background là màu đen
    ucg_SetRotate180(&ucg);                //Lat man 180
    ucg_DrawString(&ucg, 15, 12, 0, "I love"); // in dòng chữ ra LCD
    ucg_DrawString(&ucg, 10, 26, 0, "Embedded");
    ucg_DrawString(&ucg, 5, 40, 0, "Programming");

    /* Loop forever */
    while(1)
    {
        processTimerScheduler();
    }
}
